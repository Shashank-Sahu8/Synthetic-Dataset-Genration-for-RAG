# ──────────────────────────────────────────────────────────────────────────────
# Synthetic Dataset Generation – Environment Variables
# Copy this file to  backend/.env  and fill in the real values.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/synthetic_dataset_db

# LLM provider (OpenRouter)
LLM_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
